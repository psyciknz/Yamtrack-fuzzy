{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "src\\manage.py ",
            "console": "integratedTerminal",
            "args": [
                "runserver",
                "celery",
                "--app",
                "config",
                "worker",
                "--beat",
                "--scheduler",
                "django",
                "--loglevel",
                "DEBUG",
                "tailwindcss",
                "-i",
                "./static/css/input.css",
                "-o",
                "./static/css/tailwind.css",
                "--watch"
            ],
            "django": true
        },
        // launch.json
        {
            "name": "Celery",
            "type": "debugpy",
            "request": "launch",
            "module": "celery",
            "console": "integratedTerminal",
            "args": [
                "--app",
                "config",
                "worker",
                "--loglevel",
                "DEBUG",
                "--pool",
                "solo",
                "--without-mingle",
                "--without-gossip"
            ]
        },
        {
            "name": "Django",
            "type": "debugpy",
            "request": "launch",
            "stopOnEntry": false,
            "program": "${workspaceRoot}/src/manage.py",
            "args": [
                "runserver"
            ],
        },
        {
            "name": "Test File",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/manage.py",
            "args": [
                "test",
                "--noinput",
                "--keepdb",
                "src/app/tests/test_providers.py"
            ],
            "django": true
        }
    ],
    "compounds": [
        {
            "name": "Celery and Django",
            "configurations": [
                "Celery",
                "Django"
            ]
        }
    ],
}